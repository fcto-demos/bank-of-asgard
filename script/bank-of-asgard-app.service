[Unit]
Description=Bank of Asgard Frontend App
Documentation=https://github.com/asgardeo/bank-of-asgard
After=network.target

[Service]
Type=simple
User=boa
Group=boa
WorkingDirectory=/home/boa/bank-of-asgard/app

# Use a login shell so nvm/node paths from ~/.profile are available
ExecStart=/bin/bash -lc 'npm run preview'

Restart=on-failure
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=bank-of-asgard-app

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/home/boa/bank-of-asgard

[Install]
WantedBy=multi-user.target
