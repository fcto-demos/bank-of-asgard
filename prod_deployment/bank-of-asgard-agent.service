[Unit]
Description=Bank of Asgard Transactions Agent (WebSocket)
Documentation=https://github.com/fcto-demos/bank-of-asgard
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
User=boa
Group=boa
WorkingDirectory=/home/boa/bank-of-asgard/transactions-agent
EnvironmentFile=/home/boa/bank-of-asgard/transactions-agent/.env
ExecStart=/bin/bash -lc 'PYTHONPATH=/home/boa/bank-of-asgard/transactions-agent /home/boa/bank-of-asgard/transactions-agent/langchain-agent/venv/bin/amp-instrument /home/boa/bank-of-asgard/transactions-agent/langchain-agent/venv/bin/uvicorn service:app --app-dir langchain-agent --host 0.0.0.0 --port 8011'

Restart=on-failure
RestartSec=5


StandardOutput=journal
StandardError=journal
SyslogIdentifier=bank-of-asgard-agent

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/home/boa/bank-of-asgard

[Install]
WantedBy=default.target
